## 6.3 Instrumentation decorator - automatic cost tracking

| import functools                                                                                |
|-------------------------------------------------------------------------------------------------|
|                                                                                                 |
| TOKEN_PRICES = {                                                                                |
| 'gpt-4o': {'input': 5.0e-6, 'output': 15.0e-6},                                                 |
| 'gpt-4o-mini': {'input': 0.15e-6, 'output': 0.6e-6},                                            |
| 'claude-3-5-sonnet':{'input': 3.0e-6, 'output': 15.0e-6},                                       |
| 'mistral-large': {'input': 4.0e-6, 'output': 12.0e-6},                                          |
| }                                                                                               |
|                                                                                                 |
| def track_llm_call(model, provider, pipeline_id, tenant_id='default', use_case='chat'):         |
| def decorator(func):                                                                            |
| @functools.wraps(func)                                                                          |
| async def wrapper(\*args, \*\*kwargs):                                                          |
| labels = {'model': model, 'provider': provider, 'pipeline_id': pipeline_id}                     |
| t0 = time.monotonic()                                                                           |
| status = 'success'                                                                              |
| try:                                                                                            |
| result = await func(\*args, \*\*kwargs)                                                         |
| if hasattr(result, 'usage'):                                                                    |
| in_tok = result.usage.prompt_tokens                                                             |
| out_tok = result.usage.completion_tokens                                                        |
| LLM_TOKENS.labels(model=model, provider=provider, type='input').inc(in_tok)                     |
| LLM_TOKENS.labels(model=model, provider=provider, type='output').inc(out_tok)                   |
| if model in TOKEN_PRICES:                                                                       |
| p = TOKEN_PRICES\[model\]                                                                       |
| cost = in_tok \* p\['input'\] + out_tok \* p\['output'\]                                        |
| LLM_COST.labels(model=model, provider=provider,                                                 |
| tenant_id=tenant_id, use_case=use_case).inc(cost)                                               |
| return result                                                                                   |
| except Exception as e:                                                                          |
| status = type(e).\_\_name\_\_                                                                   |
| raise                                                                                           |
| finally:                                                                                        |
| LLM_DURATION.labels(\*\*labels).observe((time.monotonic()-t0)\*1000)                            |
| LLM_REQUESTS.labels(\*\*labels, status=status).inc()                                            |
| return wrapper                                                                                  |
| return decorator                                                                                |
|                                                                                                 |
| @track_llm_call(model='gpt-4o', provider='openai', pipeline_id='support-rag', tenant_id='acme') |
| async def call_llm(messages: list) -\> dict:                                                    |
| return await openai_client.chat.completions.create(model='gpt-4o', messages=messages)           |

